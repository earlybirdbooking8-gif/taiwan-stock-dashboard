# ── 複製此檔為 .env，填入真實金鑰 ──────────────────────
# cp .env.example .env

# ── AI 後端（擇一填入）──────────────────────────────────
AI_PROVIDER=claude                    # claude | openai | gemini
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxx
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxx

# ── Notion ────────────────────────────────────────────────
# 取得方式：https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
# Database ID 在 Notion DB 網址中：notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── FRED（免費，5分鐘申請）─────────────────────────────
# 申請：https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── NewsAPI（免費方案每天 100 次）───────────────────────
# 申請：https://newsapi.org/register
NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
